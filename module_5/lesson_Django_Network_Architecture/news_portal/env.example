# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Приклад змінних оточення
# ─────────────────────────────────────────────────────────────────────────────
# ІНСТРУКЦІЯ:
#   1. Скопіюй цей файл: cp .env.example .env
#   2. Замінити значення на реальні
#   3. Файл .env НЕ додається в Git (є в .gitignore)
#      → паролі залишаються приватними
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ─────────────────────────────────────────────────────────────────────
# Секретний ключ для підпису сесій, CSRF токенів тощо.
# Генерація: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-this-in-production

# DEBUG=True — детальні помилки в браузері (ТІЛЬКИ для розробки!)
# DEBUG=False — у продакшені обов'язково False
DEBUG=True

# Список дозволених хостів (через кому)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_NAME=news_portal_db
DB_USER=news_user
DB_PASSWORD=news_password
DB_HOST=db           # 'db' = ім'я сервісу в docker-compose.yml
DB_PORT=5432
